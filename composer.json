{
    "name": "students/customers-php",
    "description": "Cloud Application Development Practical Test",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "App\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "scripts": {
        "test":      "phpunit tests/ --testdox",
        "test:unit": "phpunit tests/unit --testdox",
        "test:int":  "phpunit tests/integration --testdox",
        "lint":      "find . -name '*.php' -not -path './vendor/*' -exec php -l {} +"
    }
}
